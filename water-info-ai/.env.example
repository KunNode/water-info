# ========================
# LLM 配置 (OpenAI 兼容接口)
# ========================
OPENAI_API_KEY=your-api-key
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
LLM_TIMEOUT=120
EMBEDDING_API_KEY=your-siliconflow-api-key
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ========================
# PostgreSQL
# ========================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=water_info
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# ========================
# 气象 API (可选，留空使用模拟数据)
# ========================
WEATHER_API_KEY=
DEFAULT_WEATHER_LOCATION=101010100

# ========================
# Water Platform (Spring Boot)
# ========================
WATER_PLATFORM_BASE_URL=http://localhost:8080
WATER_PLATFORM_USERNAME=admin
WATER_PLATFORM_PASSWORD=admin123

# ========================
# 服务配置
# ========================
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8100
LOG_LEVEL=INFO
RAG_TOP_K=5
RAG_MIN_SCORE=0.25
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
